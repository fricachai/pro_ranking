{
  "$schema": "https://opencode.ai/config.json",
  "shell": "powershell.exe",
  "tools": {
    "bash": true
  },
  "agent": {
    "build": {
      "mode": "primary",
      "tools": {
        "bash": true
      }
    }
  },
  "permission": {
    "edit": "deny",
    "webfetch": "deny",
    "bash": {
      "*": "deny",
      "powershell* -File *Test-OpenCodeHandoff.ps1": "allow",
      "pwsh* -File *Test-OpenCodeHandoff.ps1": "allow",
      "powershell* -File *Start-ProfessionalScreenUpdate.ps1": "allow",
      "pwsh* -File *Start-ProfessionalScreenUpdate.ps1": "allow",
      "powershell* -File *Get-ProfessionalScreenUpdateStatus.ps1*": "allow",
      "pwsh* -File *Get-ProfessionalScreenUpdateStatus.ps1*": "allow",
      "powershell* -File *Update-ProfessionalScreen.ps1 -Publish": "allow",
      "pwsh* -File *Update-ProfessionalScreen.ps1 -Publish": "allow"
    }
  }
}
